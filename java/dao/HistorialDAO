    public ResultSet obtenerHistorialCompleto(int idUsuario) {
        String sql = """
            SELECT 
                m.id_mensaje,
                m.texto_cifrado,
                m.id_estado,
                m.fecha_lectura,
                h.descripcion as descripcion_evento,
                h.fecha_hora as fecha_evento,
                t.valor_token,
                t.usado,
                t.eliminado,
                t.fecha_expiracion
            FROM mensaje m
            LEFT JOIN token t ON m.id_mensaje = t.id_mensaje
            LEFT JOIN historial h ON m.id_mensaje = h.id_mensaje
            WHERE m.id_usuario = ?
            ORDER BY m.id_mensaje DESC, h.fecha_hora DESC
        """;
        try {
            Connection conn = Conexion.getConnection();
            PreparedStatement ps = conn.prepareStatement(sql);
            ps.setInt(1, idUsuario);
            return ps.executeQuery();
        } catch (Exception e) {
            e.printStackTrace();
        }
        return null;
    }
}
