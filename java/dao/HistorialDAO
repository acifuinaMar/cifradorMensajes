public class HistorialDAO {
    public void insertar(Integer idUsuario, Integer idMensaje, int tipoEvento) {

        String sql = "INSERT INTO historial (descripcion, id_mensaje, id_tipo_evento, id_usuario) VALUES (?, ?, ?, ?)";

        try (Connection conn = Conexion.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {

            // description
            String descripcion = "";

            switch (tipoEvento) {
                case 1:
                    descripcion = "Mensaje cifrado";
                    break;
                case 2:
                    descripcion = "Mensaje leído";
                    break;
                case 3:
                    descripcion = "Intento fallido";
                    break;
                    
                case 4: 
                    descripcion = "Token eliminado";
                    break;
            }

            ps.setString(1, descripcion);

            // idMsj
            if (idMensaje != null) {
                ps.setInt(2, idMensaje);
            } else {
                ps.setNull(2, java.sql.Types.INTEGER);
            }

            // ¿Qué hicimos?
            ps.setInt(3, tipoEvento);

            // ¿Quién lo hizo?
            if (idUsuario != null) {
                ps.setInt(4, idUsuario);
            } else {
                ps.setNull(4, java.sql.Types.INTEGER);
            }

            ps.executeUpdate();

        } catch (Exception e) {
            e.printStackTrace();
        }
    }
